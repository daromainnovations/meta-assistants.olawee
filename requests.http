@baseUrl = http://localhost:3000
@apiKey = sk_webhook_secret_12345

### 1. OpenAI Chat Webhook
POST {{baseUrl}}/openai-chat
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "message": "Hola OpenAI, esto es una prueba",
  "model": "gpt-4"
}

### 2. Gemini Chat Webhook
POST {{baseUrl}}/gemini-chat
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "message": "Hola Gemini, probando webhook",
  "model": "gemini-pro"
}

### 3. Anthropic Chat Webhook
POST {{baseUrl}}/anthropic-chat
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "message": "Hola Claude, confirmando recepción",
  "model": "claude-3-opus"
}

### 4. Mistrall Chat Webhook
POST {{baseUrl}}/mistrall-chat
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "message": "Hola Mistral, test de ruta",
  "model": "mistral-large"
}

### 5. Deepseek Chat Webhook
POST {{baseUrl}}/deepseek-chat
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "message": "Hola Deepseek, verificando conexión",
  "model": "deepseek-chat"

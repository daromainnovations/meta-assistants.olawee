generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["qan8n2.0"]
}

model prueba_mensajesllms {
  id         BigInt   @id(map: "prueba_mensajesllms_pkey1") @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}

model prueba_chatsllms {
  id               BigInt    @id(map: "prueba_mensajesllms_pkey") @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  id_user_chat     String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model prueba_chatsassistants {
  id               BigInt    @id(map: "prueba_chatsassistants_pkey") @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  id_user_chat     String?   @db.VarChar
  id_assistant     String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model prueba_mensajesassistants {
  id         BigInt   @id(map: "prueba_mensajesassistants_pkey") @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["qan8n2.0", "pruebas_executions"]
}

model prueba_mensajesllms {
  id         BigInt   @id(map: "prueba_mensajesllms_pkey1") @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}

model prueba_chatsllms {
  id               BigInt    @id(map: "prueba_mensajesllms_pkey") @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model prueba_chatsassistants {
  id               BigInt    @id(map: "prueba_chatsassistants_pkey") @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  id_assistant     String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model prueba_mensajesassistants {
  id         BigInt   @id(map: "prueba_mensajesassistants_pkey") @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}



// ============================================================
// 🧪 META ASSISTANTS — Tablas de chat y mensajes
// ============================================================
model prueba_chatsmeta {
  id               BigInt    @id @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  meta_id          String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model prueba_mensajesmeta {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}


model exec_chats {
  id         String   @id @default(uuid())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  provider   String
  status     String
  input      Json?
  output     Json?

  @@schema("pruebas_executions")
}

model exec_assistants {
  id         String   @id @default(uuid())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  provider   String
  status     String
  input      Json?
  output     Json?

  @@schema("pruebas_executions")
}



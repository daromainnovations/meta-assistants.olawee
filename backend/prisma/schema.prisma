generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["meta", "meta_billing", "pruebas_executions"]
}

model chatsmeta {
  id               BigInt    @id @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  meta_id          String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("meta")
}

model mensajesmeta {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("meta")
}

model MetaAssistantCatalog {
  meta_id     String  @id
  name        String
  description String?
  category    String
  is_premium  Boolean @default(false)
  access_type String  @default("PUBLIC")
  owner_id    Int?
  total_uses  Int     @default(0)

  @@schema("meta")
}

model UserProfile {
  id           Int          @id
  plan_type    String       @default("FREE")
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  usage_events UsageEvent[]
  user_access  UserAccess[]

  @@schema("meta_billing")
}

model UsageEvent {
  request_id String      @id
  user_id    Int
  meta_id    String
  status     String      @default("STARTED")
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  updated_at DateTime    @updatedAt @db.Timestamptz(6)
  user       UserProfile @relation(fields: [user_id], references: [id])

  @@index([user_id, meta_id])
  @@schema("meta_billing")
}

model UserAccess {
  id           Int         @id @default(autoincrement())
  user_id      Int
  meta_id      String
  access_level String      @default("UNLIMITED")
  granted_at   DateTime    @default(now()) @db.Timestamptz(6)
  user         UserProfile @relation(fields: [user_id], references: [id])

  @@unique([user_id, meta_id])
  @@schema("meta_billing")
}

model executions {
  id          String   @id @default(uuid())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  category    String
  provider    String
  environment String
  status      String
  duration_ms Int?
  input       Json?
  output      Json?
  error       Json?

  @@schema("pruebas_executions")
}

model exec_assistants {
  id         String   @id
  created_at DateTime @default(now()) @db.Timestamptz(6)
  provider   String
  status     String
  input      Json?
  output     Json?

  @@schema("pruebas_executions")
}

model exec_chats {
  id         String   @id
  created_at DateTime @default(now()) @db.Timestamptz(6)
  provider   String
  status     String
  input      Json?
  output     Json?

  @@schema("pruebas_executions")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["qan8n2.0", "pruebas_executions"]
}

model mensajesllms {
  id         BigInt   @id(map: "prueba_mensajesllms_pkey1") @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}

model chatsllms {
  id               BigInt    @id(map: "prueba_mensajesllms_pkey") @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model chats_agentes {
  id               BigInt    @id(map: "prueba_chatsassistants_pkey") @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  id_assistant     String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model mensajes_agentes {
  id         BigInt   @id(map: "prueba_mensajesassistants_pkey") @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}



// ============================================================
// 🧪 META ASSISTANTS — Tablas de chat y mensajes
// ============================================================
model chatsmeta {
  id               BigInt    @id @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  meta_id          String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model mensajesmeta {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}


model exec_chats {
  id         String   @id @default(uuid())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  provider   String
  status     String
  input      Json?
  output     Json?

  @@schema("pruebas_executions")
}

model exec_assistants {
  id         String   @id @default(uuid())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  provider   String
  status     String
  input      Json?
  output     Json?

  @@schema("pruebas_executions")
}


// ============================================================
// 🛡️ EXECUTIONS — Tabla Unificada de Control de Ejecuciones
// ============================================================
// Registra todas las ejecuciones del sistema:
//   category  → 'llm' | 'assistant' | 'meta'
//   provider  → modelo específico o meta_id del especialista
//   environment → 'staging' | 'production'
//   status    → 'SUCCESS' | 'ERROR'
//   duration_ms → tiempo de respuesta en milisegundos
//   error     → null si SUCCESS, traza completa si ERROR
// ============================================================
model executions {
  id          String   @id @default(uuid())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  category    String   // 'llm' | 'assistant' | 'meta'
  provider    String   // 'openai' | 'gemini' | 'assistant' | 'invoice_checker' | ...
  environment String   // 'staging' | 'production'
  status      String   // 'SUCCESS' | 'ERROR'
  duration_ms Int?     // Tiempo de respuesta en ms
  input       Json?
  output      Json?
  error       Json?    // null si SUCCESS

  @@schema("pruebas_executions")
}

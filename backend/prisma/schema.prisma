generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["qan8n2.0", "pruebas_executions"]
}

// ============================================================
// 🤖 META ASSISTANTS — Tablas de chat y mensajes
// ============================================================
model chatsmeta {
  id               BigInt    @id @default(autoincrement())
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  session_id       String?   @db.VarChar
  meta_id          String?   @db.VarChar
  titulo           String?
  systemprompt_doc String?
  updated_at       DateTime? @db.Timestamptz(6)

  @@schema("qan8n2.0")
}

model mensajesmeta {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  message    Json?
  session_id String?  @db.VarChar

  @@schema("qan8n2.0")
}


// ============================================================
// 🛡️ EXECUTIONS — Tabla Unificada de Control de Ejecuciones
// ============================================================
// Registra todas las ejecuciones del sistema Meta:
//   category  → 'meta'
//   provider  → meta_id del especialista (ej. 'invoice_checker')
//   environment → 'staging' | 'production'
//   status    → 'SUCCESS' | 'ERROR'
//   duration_ms → tiempo de respuesta en milisegundos
//   error     → null si SUCCESS, traza completa si ERROR
// ============================================================
model executions {
  id          String   @id @default(uuid())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  category    String   // 'meta'
  provider    String   // 'invoice_checker', 'cv_screening_rrhh', etc.
  environment String   // 'staging' | 'production'
  status      String   // 'SUCCESS' | 'ERROR'
  duration_ms Int?     // Tiempo de respuesta en ms
  input       Json?
  output      Json?
  error       Json?    // null si SUCCESS

  @@schema("pruebas_executions")
}
